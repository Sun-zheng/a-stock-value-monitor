# AI股票分析系统环境配置模板
# 复制为 .env 后填写真实密钥；.env 已被 gitignore 忽略，不要提交真实值。

# ========== DeepSeek API配置 ==========
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# ========== ModelScope API配置 ==========
MODELSCOPE_API_KEY=""
MODELSCOPE_BASE_URL="https://api-inference.modelscope.cn/v1"

# 经过验证后建议放入默认轮询池的 ModelScope 文本模型。
AI_MODEL_POOL="deepseek-ai/DeepSeek-V4-Flash,stepfun-ai/Step-3.7-Flash,moonshotai/Kimi-K2.7-Code:Moonshot"

# ========== 可选供应商 ==========
ALIYUN_API_KEY=""
ALIYUN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
SILICONFLOW_API_KEY=""
SILICONFLOW_BASE_URL="https://api.siliconflow.cn/v1"
NVIDIA_API_KEY=""
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"

# ========== 数据源 ==========
TUSHARE_TOKEN=""

# ========== 邮件/Webhook ==========
EMAIL_ENABLED="false"
SMTP_SERVER=""
SMTP_PORT="587"
EMAIL_FROM=""
EMAIL_PASSWORD=""
EMAIL_TO=""
WEBHOOK_ENABLED="false"
WEBHOOK_TYPE="feishu"
WEBHOOK_URL=""
WEBHOOK_KEYWORD="aiagents通知"
